[k3s_cluster:vars]
smoke_test_image=busybox:1.36.1

# Local Test Inventory
# Purpose: Inventory for smoke tests against localhost or local VM
# Usage: ansible-playbook -i tests/ansible/inventories/local tests/ansible/smoke/smoke.yml

[k3s_servers]
# localhost ansible_connection=local
k3s-server-01 ansible_host=192.168.50.121 ansible_user=ansible

[k3s_agents]
# k3s-agent-01 ansible_host=192.168.1.111 ansible_user=ansible

[k3s_cluster:children]
k3s_servers
k3s_agents

[k3s_cluster:vars]
control_plane_vip=192.168.50.8
api_port=6443
ansible_ssh_common_args='-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null'

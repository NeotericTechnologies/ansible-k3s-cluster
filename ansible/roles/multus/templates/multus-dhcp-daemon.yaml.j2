---
# Multus DHCP daemon DaemonSet
# Purpose: Runs the CNI DHCP daemon on each node to proxy DHCP requests from
# pods using DHCP-based IPAM to the external DHCP server on the VLAN.
# The dhcp binary is provided by k3s bundled CNI plugins at multus_cni_bin_dir.
# Reference: https://www.cni.dev/plugins/current/ipam/dhcp/
# Constraint: No symlinks, no file copies, no k3s path modifications (R-013)
apiVersion: apps/v1
kind: DaemonSet
metadata:
  name: multus-dhcp-daemon
  namespace: {{ multus_namespace }}
  labels:
    app: multus-dhcp-daemon
    k8s-app: multus-dhcp
spec:
  selector:
    matchLabels:
      app: multus-dhcp-daemon
  updateStrategy:
    type: RollingUpdate
    rollingUpdate:
      maxUnavailable: 1
  template:
    metadata:
      labels:
        app: multus-dhcp-daemon
        k8s-app: multus-dhcp
    spec:
      hostNetwork: true
      tolerations:
        - operator: Exists
          effect: NoSchedule
        - operator: Exists
          effect: NoExecute
      initContainers:
        - name: clean-dhcp-socket
          image: {{ multus_dhcp_daemon_image }}
          command: ["/bin/sh", "-c", "rm -f /host/run/cni/dhcp.sock"]
          volumeMounts:
            - name: run-cni
              mountPath: /host/run/cni
      containers:
        - name: dhcp-daemon
          image: {{ multus_dhcp_daemon_image }}
          command:
            - /host/cni-bin/dhcp
            - daemon
            - -hostprefix
            - /host
          resources:
            requests:
              cpu: 10m
              memory: 32Mi
            limits:
              cpu: 100m
              memory: 64Mi
          securityContext:
            privileged: true
          volumeMounts:
            - name: cni-bin
              mountPath: /host/cni-bin
              readOnly: true
            - name: run-cni
              mountPath: /host/run/cni
            - name: proc
              mountPath: /host/proc
            - name: netns
              mountPath: /host/var/run/netns
              mountPropagation: HostToContainer
      volumes:
        - name: cni-bin
          hostPath:
            path: {{ multus_cni_bin_dir }}
            type: Directory
        - name: run-cni
          hostPath:
            path: /run/cni
            type: DirectoryOrCreate
        - name: proc
          hostPath:
            path: /proc
            type: Directory
        - name: netns
          hostPath:
            path: /run/netns
            type: DirectoryOrCreate

---
# DNS provider credentials secret
# Reference: FR-017 (provider-agnostic DNS-01)
apiVersion: v1
kind: Secret
metadata:
  name: cert-manager-dns-credentials
  namespace: cert-manager
type: Opaque
stringData:
{% for key, value in cert_manager_dns_provider_credentials.items() %}
  {{ key }}: {{ value }}
{% endfor %}

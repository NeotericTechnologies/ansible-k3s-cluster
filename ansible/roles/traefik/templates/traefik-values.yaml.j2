---
# Traefik Helm values template
# Reference: FR-009

service:
  type: {{ traefik_service_type | default('LoadBalancer') }}

ports:
  web:
    port: 8000
    exposedPort: 80
    protocol: TCP
  websecure:
    port: 8443
    exposedPort: 443
    protocol: TCP

{% if traefik_additional_entrypoints is defined %}
additionalArguments:
{% for ep in traefik_additional_entrypoints %}
  - "--entrypoints.{{ ep.name }}.address=:{{ ep.port }}/{{ ep.protocol | default('tcp') }}"
{% endfor %}
{% endif %}

deployment:
  replicas: {{ traefik_replicas | default(1) }}

ingressRoute:
  dashboard:
    enabled: {{ traefik_dashboard_enabled | default(false) | lower }}

logs:
  general:
    level: {{ traefik_log_level | default('ERROR') }}
